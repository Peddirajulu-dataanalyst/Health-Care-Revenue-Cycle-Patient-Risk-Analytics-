      <column caption='Total Patients' datatype='integer' name='[Calculation_2364776858636288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([patient_id])' />
      </column>
      <column caption='Total Visits' datatype='integer' name='[Calculation_2364776859648001]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([visit_id (clean_visits.csv)])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_2364776860307458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([treatment_cost])' />
      </column>
      <column caption='Claim Approval %' datatype='real' name='[Calculation_2364776860954627]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [claim_status]=&quot;Approved&quot; THEN [claim_id] END)/COUNT([claim_id])' />
      </column>
      <column caption='Readdmission Rate' datatype='real' name='[Calculation_2364776915165188]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [readmission_flag]=&quot;Yes&quot; THEN [followup_id] END)/COUNT([followup_id])' />
      </column>
      <column caption='Denied Claims' datatype='integer' name='[Calculation_2364776928210951]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [claim_status]=&quot;Denied&quot; THEN [claim_id] END)' />
      </column>
      <column caption='Age Group ' datatype='string' name='[Calculation_2364777238106120]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt;= 30 THEN &quot;18-30&quot; ELSEIF [age] &lt;= 45 THEN &quot;31-45&quot; ELSEIF [age] &lt;= 60 THEN &quot;46-60&quot; ELSE &quot;60+&quot; END' />
      </column>
